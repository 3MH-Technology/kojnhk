# =============================================================================
# WormGPT - Root environment template
# Copy to .env and fill in. Never commit real secrets.
# =============================================================================

# ---- Core ----
NODE_ENV=development
ENV=development
APP_NAME=WormGPT
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# ---- MongoDB Atlas ----
# Get from https://cloud.mongodb.com → Cluster → Connect → Drivers
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=wormgpt

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ---- Auth ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-me-with-a-long-random-string-at-least-64-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAY=14
CSRF_SECRET=replace-me-too-64-chars-min
COOKIE_SECURE=false

# ---- Encryption (for API keys) ----
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ---- AI Providers ----
# Primary: Groq (real)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Other providers stubbed - fill these in to enable
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ---- Web Search ----
# Provider for /api/web/search. Defaults to a built-in DuckDuckGo scraper.
WEB_SEARCH_PROVIDER=duckduckgo
SERPER_API_KEY=
TAVILY_API_KEY=

# ---- Limits ----
RATE_LIMIT_PER_MIN=120
MAX_UPLOAD_MB=20
MAX_CONTEXT_TOKENS=32000

# ---- Observability ----
LOG_LEVEL=INFO
SENTRY_DSN=

# ---- Bootstrap ----
# First-time super admin created on app startup if no users exist.
BOOTSTRAP_ADMIN_EMAIL=admin@falaki-ai.pages.dev
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_USERNAME=admin
